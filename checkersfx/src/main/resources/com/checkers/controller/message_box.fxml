<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<StackPane style="-fx-background-color: transparent; -fx-padding: 24;" 
           xmlns="http://javafx.com/javafx/21" 
           xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="com.checkers.controller.MessageBoxController">
    
    <VBox fx:id="rootBox" prefWidth="420.0" spacing="16.0" styleClass="settings-dialog" stylesheets="@style.css">
        <padding>
            <Insets top="24.0" right="28.0" bottom="24.0" left="28.0"/>
        </padding>

        <HBox alignment="CENTER_LEFT">
            <Label fx:id="titleLabel" text="Title" styleClass="settings-title"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="X" onAction="#handleClose" styleClass="close-button"/>
        </HBox>

        <VBox fx:id="contentArea" spacing="16.0" alignment="CENTER">
            <padding>
                <Insets top="8" bottom="8"/>
            </padding>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="12" fx:id="footerArea">
            <Button text="Confirm" onAction="#handleClose" styleClass="apply-button"/>
        </HBox>
    </VBox>
</StackPane>
