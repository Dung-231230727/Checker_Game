<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<VBox fx:id="rootBox" spacing="24.0" xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.checkers.controller.SettingsController"
      stylesheets="@style.css"
      alignment="CENTER">
    
    <padding>
        <Insets top="28.0" right="32.0" bottom="28.0" left="32.0"/>
    </padding>

    <Label text="Settings" style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #0f172a;">
        <VBox.margin>
            <Insets bottom="8" />
        </VBox.margin>
    </Label>

    <VBox spacing="4.0" styleClass="ai-config-section">
        <HBox alignment="CENTER_LEFT" styleClass="settings-row" style="-fx-padding: 12 0 12 0;">
            <Label text="Sound Effects" styleClass="settings-label"/>
            <Region HBox.hgrow="ALWAYS" />
            <StackPane fx:id="toggleSound" onMouseClicked="#handleToggleSound" styleClass="toggle-track">
                <Circle fx:id="dotSound" radius="10" styleClass="toggle-dot" translateX="-12"/>
            </StackPane>
        </HBox>

        <Separator style="-fx-padding: 0;" />

        <HBox alignment="CENTER_LEFT" styleClass="settings-row" style="-fx-padding: 12 0 12 0;">
            <Label text="Background Music" styleClass="settings-label"/>
            <Region HBox.hgrow="ALWAYS" />
            <StackPane fx:id="toggleMusic" onMouseClicked="#handleToggleMusic" styleClass="toggle-track">
                <Circle fx:id="dotMusic" radius="10" styleClass="toggle-dot" translateX="-12"/>
            </StackPane>
        </HBox>

        <Separator style="-fx-padding: 0;" />

        <HBox alignment="CENTER_LEFT" styleClass="settings-row" style="-fx-padding: 12 0 12 0;">
            <Label text="Vibration" styleClass="settings-label"/>
            <Region HBox.hgrow="ALWAYS" />
            <StackPane fx:id="toggleVibration" onMouseClicked="#handleToggleVibration" styleClass="toggle-track">
                <Circle fx:id="dotVibration" radius="10" styleClass="toggle-dot" translateX="-12"/>
            </StackPane>
        </HBox>
    </VBox>

    <Region prefHeight="8" />

    <VBox alignment="CENTER" spacing="12.0">
        <Button fx:id="btnExitToMenu" 
                text="Exit to Main Menu" 
                onAction="#handleExitToMenu" 
                styleClass="game-button-red" 
                prefWidth="200.0"/>
        <Label text="Current game will be cancelled" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
    </VBox>

</VBox>
