<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="750.0" prefWidth="1000.0" 
            stylesheets="@style.css" 
            xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.checkers.controller.GameController">
    
    <top>
        <HBox alignment="CENTER" styleClass="bar-background" prefHeight="56.0">
            <padding>
                <Insets left="24.0" right="24.0" />
            </padding>
            <Label fx:id="totalTimerLabel" styleClass="time-text" text="10:00" style="-fx-font-size: 15px;" />
        </HBox>
    </top>

    <center>
        <HBox fx:id="mainHBox" alignment="CENTER" style="-fx-background-color: #f8fafc;">
            
            <VBox fx:id="panelP1" HBox.hgrow="ALWAYS" maxWidth="Infinity" minWidth="200.0" alignment="TOP_CENTER" spacing="16.0" styleClass="side-panel">
                <padding><Insets top="32.0" left="16.0" right="16.0" bottom="32.0"/></padding>
                <Circle fx:id="player1ColorCircle" fill="WHITE" radius="28.0" stroke="#e2e8f0" strokeWidth="3.0" />
                <Label fx:id="player1NameLabel" styleClass="player-text" text="Player 1" />
                <Label fx:id="player1TimerLabel" styleClass="time-text" text="60s" />
                <Region VBox.vgrow="ALWAYS" /> 
                <VBox fx:id="controlsP1" spacing="10.0" alignment="CENTER">
                    <Button fx:id="btnPauseP1" text="Pause" onAction="#handlePause" styleClass="side-button"/>
                    <Button fx:id="btnUndoP1" text="Undo" onAction="#handleUndoMove" styleClass="side-button"/>
                    <Button fx:id="btnHintP1" text="Hint" onAction="#handleShowHint" styleClass="side-button"/>
                    <Button fx:id="btnSurrenderP1" text="Surrender" onAction="#handleSurrender" styleClass="side-button"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
            </VBox>

            <StackPane fx:id="centerContainer" HBox.hgrow="NEVER">
                <padding><Insets bottom="16.0" left="32.0" right="32.0" top="16.0" /></padding>
                
                <Label fx:id="pauseLabel" text="PAUSED" visible="false" managed="false" 
                       styleClass="pause-overlay" StackPane.alignment="CENTER" />
            </StackPane>

            <VBox fx:id="panelP2" HBox.hgrow="ALWAYS" maxWidth="Infinity" minWidth="200.0" alignment="TOP_CENTER" spacing="16.0" styleClass="side-panel" style="-fx-border-width: 0 0 0 1;">
                <padding><Insets top="32.0" left="16.0" right="16.0" bottom="32.0"/></padding>
                <Circle fx:id="player2ColorCircle" fill="#0ea5e9" radius="28.0" stroke="#e2e8f0" strokeWidth="3.0" />
                <Label fx:id="player2NameLabel" styleClass="player-text" text="Player 2" />
                <Label fx:id="player2TimerLabel" styleClass="time-text" text="60s" />
                <Region VBox.vgrow="ALWAYS" />
                <VBox fx:id="controlsP2" spacing="10.0" alignment="CENTER">
                    <Button fx:id="btnPauseP2" text="Pause" onAction="#handlePause" styleClass="side-button"/>
                    <Button fx:id="btnUndoP2" text="Undo" onAction="#handleUndoMove" styleClass="side-button"/>
                    <Button fx:id="btnHintP2" text="Hint" onAction="#handleShowHint" styleClass="side-button"/>
                    <Button fx:id="btnSurrenderP2" text="Surrender" onAction="#handleSurrender" styleClass="side-button"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
            </VBox>

        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="16.0" styleClass="bar-background" prefHeight="72.0" style="-fx-border-width: 1 0 0 0;">
            <padding><Insets bottom="16.0" left="32.0" right="32.0" top="16.0" /></padding>
            <Button text="Settings" onAction="#handleOpenSettings" styleClass="game-button"/>
            <Button fx:id="btnMatchSettings" text="Match Settings" onAction="#handleOpenMatchSettings" styleClass="game-button"/>
            <Region HBox.hgrow="ALWAYS" /> 
            <Button fx:id="btnPauseSystem" text="Pause" onAction="#handlePause" 
                    styleClass="game-button" visible="false" managed="false"/>
            <Button fx:id="btnStart" styleClass="apply-button" text="Start Game" onAction="#handleStartGame"/>
            <Button fx:id="btnExit" styleClass="game-button" text="Exit Game" onAction="#handleExitToMenu"/>
        </HBox>
    </bottom>
</BorderPane>
