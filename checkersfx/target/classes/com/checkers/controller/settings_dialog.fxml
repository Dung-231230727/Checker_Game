<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<VBox fx:id="rootBox" spacing="20.0" xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.checkers.controller.SettingsController"
      stylesheets="@style.css">
    
    <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
    </padding>

    <VBox spacing="15.0">
        <HBox alignment="CENTER_LEFT" styleClass="settings-row">
            <Label text="Âm thanh" styleClass="settings-label"/>
            <Region HBox.hgrow="ALWAYS" />
            <StackPane fx:id="toggleSound" onMouseClicked="#handleToggleSound" styleClass="toggle-track">
                <Circle fx:id="dotSound" radius="10" styleClass="toggle-dot" translateX="-12"/>
            </StackPane>
        </HBox>

        <HBox alignment="CENTER_LEFT" styleClass="settings-row">
            <Label text="Nhạc nền" styleClass="settings-label"/>
            <Region HBox.hgrow="ALWAYS" />
            <StackPane fx:id="toggleMusic" onMouseClicked="#handleToggleMusic" styleClass="toggle-track">
                <Circle fx:id="dotMusic" radius="10" styleClass="toggle-dot" translateX="-12"/>
            </StackPane>
        </HBox>

        <HBox alignment="CENTER_LEFT" styleClass="settings-row">
            <Label text="Rung" styleClass="settings-label"/>
            <Region HBox.hgrow="ALWAYS" />
            <StackPane fx:id="toggleVibration" onMouseClicked="#handleToggleVibration" styleClass="toggle-track">
                <Circle fx:id="dotVibration" radius="10" styleClass="toggle-dot" translateX="-12"/>
            </StackPane>
        </HBox>
    </VBox>

    </VBox>