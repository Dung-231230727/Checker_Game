<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="25.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.checkers.controller.MainMenuController">
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
    </padding>

    <Label styleClass="title-label" text="Checker Game" textAlignment="CENTER">
      <VBox.margin>
         <Insets bottom="30.0" />
      </VBox.margin></Label>

    <HBox alignment="CENTER" spacing="15.0">
        <Button fx:id="btnSelectMode" mnemonicParsing="false" onAction="#showModeMenu" prefHeight="55.0" prefWidth="130.0" styleClass="menu-button" text="Chế độ ▾" />
        <Button fx:id="btnStartGame" mnemonicParsing="false" onAction="#handleStartSelectedMode" prefHeight="55.0" prefWidth="250.0" styleClass="menu-button, primary-button" text="BẮT ĐẦU: PVP" />
    </HBox>
    <Button mnemonicParsing="false" onAction="#handleOpenMatchSettings" prefHeight="55.0" prefWidth="280.0" styleClass="menu-button" text="Thiết lập máy" fx:id="btnMatchSettings"/>
    <Button mnemonicParsing="false" onAction="#handleSettings" prefHeight="55.0" prefWidth="280.0" styleClass="menu-button" text="Cài đặt" />
    <Button mnemonicParsing="false" onAction="#handleInstructions" prefHeight="55.0" prefWidth="280.0" styleClass="menu-button" text="Hướng dẫn" />
    <Button mnemonicParsing="false" onAction="#onExit" prefHeight="55.0" prefWidth="280.0" styleClass="menu-button" text="Thoát" />
</VBox>
